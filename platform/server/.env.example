# Codress API 配置(复制为 .env 使用)

PORT=8080
GIN_MODE=debug

# 数据库:生产用 mysql;本地快速联调可切 sqlite(DB_DSN 填文件路径)
DB_DRIVER=mysql
DB_DSN=root:codress@tcp(127.0.0.1:3306)/codress?charset=utf8mb4&parseTime=True&loc=Local

# JWT 密钥,生产必须改
JWT_SECRET=codress-dev-secret-change-me

# 上传文件目录(会通过 /static 对外提供)
STORAGE_DIR=./storage

# 对外可访问的基础 URL(拼接资源下载地址、OAuth 回调)
PUBLIC_BASE_URL=http://127.0.0.1:8080

# 初始管理员(首次启动 seed,之后改密码)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=codress123

# GitHub OAuth App: https://github.com/settings/developers
# 回调地址填 <PUBLIC_BASE_URL>/api/v1/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth: https://console.cloud.google.com/apis/credentials
# 回调地址填 <PUBLIC_BASE_URL>/api/v1/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 开发登录(未配置任何 OAuth 时默认开启;生产设为 0)
# DEV_LOGIN=0
